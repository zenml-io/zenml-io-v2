---
/**
 * MinimalLayout — lightweight HTML shell WITHOUT Navigation/Footer chrome.
 *
 * Used for redirect-only pages, iframe embeds (Storylane), and other pages
 * where the full site chrome would flash unnecessarily before a redirect
 * or where the page content fills the entire viewport (e.g., fullscreen iframe).
 *
 * Shares the same <head> SEO contract as BaseLayout via SEOProps.
 */
import { resolveSeo, type SEOProps } from "../lib/seo";
import PlausibleBridge from "../components/analytics/PlausibleBridge.astro";
import CookieConsent from "../components/islands/CookieConsent.tsx";
import "../styles/global.css";

interface Props extends SEOProps {
  bodyClass?: string;
}

const { bodyClass, ...seoProps } = Astro.props;
const seo = resolveSeo(seoProps, Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Core SEO */}
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:url" content={seo.canonical} />
    {seo.ogImage && <meta property="og:image" content={seo.ogImage} />}

    {/* Twitter Card */}
    <meta name="twitter:card" content={seo.twitterCard} />
    <meta name="twitter:title" content={seo.ogTitle} />
    <meta name="twitter:description" content={seo.ogDescription} />
    {seo.ogImage && <meta name="twitter:image" content={seo.ogImage} />}

    {/* Favicon */}
    <link rel="icon" type="image/png" href="/favicon.png" />

    {/* Plausible — cookieless, GDPR-compliant analytics. Loaded directly
        (not gated behind cookie consent) since it doesn't use cookies or
        track personal data. Hostname-gated to prevent preview deploy noise. */}
    <script is:inline>
      if (["www.zenml.io","zenml.io"].includes(window.location.hostname)) {
        var s = document.createElement("script");
        s.defer = true;
        s.setAttribute("data-domain", "zenml.io");
        s.src = "https://plausible.io/js/script.js";
        document.head.appendChild(s);
      }
    </script>

    {/* RB2B — visitor identification for B2B lead gen. Loaded directly
        (not gated behind cookie consent) to match original Webflow behavior.
        Hostname-gated to prevent preview deploy noise. */}
    <script is:inline>
      if (["www.zenml.io","zenml.io"].includes(window.location.hostname)) {
        !function(){var reb2b=window.reb2b=window.reb2b||[];if(reb2b.invoked)return;reb2b.invoked=true;reb2b.methods=["identify","collect"];reb2b.factory=function(method){return function(){var args=Array.prototype.slice.call(arguments);args.unshift(method);reb2b.push(args);return reb2b}};for(var i=0;i<reb2b.methods.length;i++){var key=reb2b.methods[i];reb2b[key]=reb2b.factory(key)}reb2b.load=function(key){var script=document.createElement("script");script.type="text/javascript";script.async=true;script.src="https://s3-us-west-2.amazonaws.com/b2bjsstore/b/"+key+"/Z6PVLHP07Q6R.js.gz";var first=document.getElementsByTagName("script")[0];first.parentNode.insertBefore(script,first)};reb2b.SNIPPET_VERSION="1.0.1";reb2b.load("Z6PVLHP07Q6R")}();
      }
    </script>

    {/* Other analytics (GA4, Segment, etc.) and third-party scripts are
        injected dynamically by the CookieConsent island after user consent.
        See consentConfig.ts. */}
  </head>
  <body class:list={["min-h-screen bg-white text-gray-900 antialiased", bodyClass]}>
    <slot />
    <PlausibleBridge />
    <CookieConsent client:load />
  </body>
</html>
